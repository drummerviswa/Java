							mark.updateResults();
							break;
						case 3:
							mark.viewResults();
							break;
						case 4:
							mark.deleteResults();
							break;
						case 5:
							mark.updateAttendance();
							break;
						case 6:
							System.out.println("Logging out....");
							break logout;
						default:
							break;
