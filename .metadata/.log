	public static int calculateInternal(int a1,int a2,int a3,int credit) {
		int temp;
		switch(credit) {
			case 2:
				return  (int)(a2*0.6);
			case 3:
				temp=a1+a2;
				temp=temp/2;
				return (int)(temp*0.4);
			case 4:
				temp=a1+a2;
				temp=temp/2;
				return (int)(temp*0.4);
			case 5:
				temp=a1+a2;
				temp=temp/2;
				return (int)(temp*0.4);
			default:
				return (int)(a1+a2+a3)/3;
		}
	}
	private int calculateEndSem(int b,int c) {
		switch(c) {
		case 2:
			return (int)(b*0.4);
		default:
			return (int)(b*0.6);
		}
	}
