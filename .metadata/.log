	        try (ResultSet resultSet = statement.executeQuery()) {
	            if (resultSet.next()) {
	                c = resultSet.getInt("Credits");
	            }
	        }
	    }
	    return c;
	}
	private int getTotalPeriods(String subject) throws SQLException{
