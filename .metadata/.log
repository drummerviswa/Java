						+ "4. Delete Marks\n"
						+ "5. Update Attendance\n"
						+ "6. Logout as Student"
						+ "Enter your choice: "+RESET);
				option=s.nextInt();
				if(option!=0) {
					switch(option) {
						case 1:
							mark.enterResults();
							break;
						case 2:
							mark.updateResults();
							break;
						case 3:
							mark.viewResults();
							break;
						case 4:
							mark.deleteResults();
							break;
						case 5:
							mark.updateAttendance();
							break;
						case 6:
							System.out.println("Logging out....");
							break logout;
						default:
							break;
					}
				}
			}while(option!=6);
	}
