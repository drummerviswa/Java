	}
	public static int calculateInternal(int a1,int a2,int a3,int credit) {
		int internal=0;
		switch(credit) {
			case 2:
				internal = a2*(40/100);
				break;
			case 3|4|5:
				internal = ((a1+a2)/2)*(40/100);
				break;
			default:
				internal = (a1+a2+a3)/3;
				break;
		}
		return internal;
	}
